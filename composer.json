{
    "name": "recca0120/quick-order",
    "description": "WooCommerce Quick Order plugin",
    "type": "wordpress-plugin",
    "license": "MIT",
    "require": {
        "php": ">=7.2",
        "recca0120/wp-reverse-proxy": "dev-main"
    },
    "require-dev": {
        "phpunit/phpunit": "^8.5 || ^9.5",
        "wp-phpunit/wp-phpunit": "^6.6",
        "yoast/phpunit-polyfills": "^2.0",
        "nyholm/psr7": "^1.5"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/recca0120/wp-reverse-proxy"
        }
    ],
    "autoload": {
        "psr-4": {
            "Recca0120\\QuickOrder\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Recca0120\\QuickOrder\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "extra": {
        "strauss": {
            "target_directory": "vendor-prefixed",
            "namespace_prefix": "Recca0120\\QuickOrder\\Vendor\\",
            "classmap_prefix": "Recca0120_QuickOrder_Vendor_",
            "constant_prefix": "RECCA0120_QUICK_ORDER_VENDOR_",
            "delete_vendor_packages": true,
            "delete_vendor_files": true,
            "include_root_autoload": true
        }
    }
}
